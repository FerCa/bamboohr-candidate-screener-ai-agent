# BambooHR credentials
BAMBOOHR_API_KEY=
BAMBOOHR_SUBDOMAIN=

# OpenAI credentials (used in Phase 3)
OPENAI_API_KEY=

# Runtime flags
# By default the script runs in dry-run mode and makes no writes to BambooHR.
# Set LIVE_MODE=true to enable live writes (Phase 4+). Requires signed DPA with OpenAI first.
# LIVE_MODE=true
# CONFIG_PATH defaults to ./config.yaml if not set
CONFIG_PATH=./config.yaml
